# Plugfile environment template — copy to `.env` and fill in real values.
# `.env` is gitignored; this `.env.example` is committed as documentation.

# Required for OCR of scanned/image GAU letters (Phase 2C).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: pin a specific Claude model for GAU OCR (otherwise auto-selected,
# preferring Sonnet for digit accuracy).
# PLUGFILE_LLM_MODEL=claude-sonnet-4-6

# Optional: use live RRC data instead of the MockFetcher in the web API.
# PLUGFILE_RRC_LIVE=true

# Optional: enable the LLM fallback slot extractor for Section IX narrative.
# PLUGFILE_LLM_FALLBACK=true

# ---------------------------------------------------------------------------
# Authentication (optional). If PLUGFILE_AUTH_JWKS_URL is unset, the app runs
# in OPEN mode (no login, behaves as a public web form). Set these to require
# sign-in for the final/paid PDF (and, later, save/resume).
#
# Reference setup uses Supabase Auth (free; Google/Facebook/Apple/email):
#   1. Create a Supabase project; enable the providers under Authentication.
#   2. The JWKS URL is <project-url>/auth/v1/.well-known/jwks.json
#   3. The anon key is PUBLIC by design (RLS protects data) — safe to expose.
#      NEVER put the service-role key or JWT secret here / in the frontend.
# Works with any provider exposing a JWKS endpoint (Auth0, Clerk, …).
# PLUGFILE_AUTH_PROVIDER=supabase
# PLUGFILE_AUTH_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# PLUGFILE_AUTH_ISSUER=https://YOUR-PROJECT.supabase.co/auth/v1
# PLUGFILE_AUTH_AUDIENCE=authenticated
# PLUGFILE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# PLUGFILE_SUPABASE_ANON_KEY=eyJhbGciOi...your-public-anon-key...
